# Production placeholders — replace with real values at deploy time.
# Do NOT commit real secrets to a public repository.

DATABASE_URL=postgres://REPLACE_USER:REPLACE_PASSWORD@REPLACE_HOST:5432/REPLACE_DB?sslmode=require
CORS_ALLOW_ORIGINS=https://example.com,https://www.example.com
SERVER_ADDR=:8080

AUTH0_DOMAIN=your-tenant.au.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_CALLBACK_URL=https://api.example.com/api/auth/callback
AUTH0_AUDIENCE=https://your-api-identifier
AUTH0_POST_LOGIN_REDIRECT=https://example.com/
AUTH0_LOGOUT_RETURN_URL=https://example.com/login
AUTH0_CONNECTION=email
AUTH0_COOKIE_SECURE=true
AUTH0_CORS_ORIGINS=https://example.com
